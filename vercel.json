{
  "rewrites": [
    { "source": "/flo", "destination": "/index.html" },
    { "source": "/max", "destination": "/index.html" },
    { "source": "/andy", "destination": "/index.html" },
    { "source": "/sandro", "destination": "/index.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/notify?time=midday", "schedule": "0 10 * * *" },
    { "path": "/api/notify?time=evening", "schedule": "0 18 * * *" }
  ]
}
